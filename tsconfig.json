{
  "compilerOptions": {
    "target": "ES2019",
    "module": "None",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "js",
    "rootDir": "src",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
